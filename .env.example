# Radar Environment Configuration
# Copy this to .env and add your API keys

# Core API Keys (Free/Required)
GITHUB_TOKEN=ghp_your_github_token_here

# Optional API Keys (Add as needed)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT="Radar:v1.0 (by /u/your_username)"

# System Configuration
RADAR_DATA_DIR=./raw
RADAR_STATE_DIR=./state
RADAR_LOG_LEVEL=INFO

# Rate Limiting
RADAR_MAX_REQUESTS_PER_MINUTE=60
RADAR_REQUEST_DELAY_MS=1000